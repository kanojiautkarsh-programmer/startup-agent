# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# SSO / SAML CONFIGURATION
# ===========================================
# Admin email for accessing audit logs
ADMIN_EMAIL=admin@example.com

# SAML Certificate (for signing SAML requests)
# SAML_PRIVATE_KEY=your-private-key-base64
# SAML_CERTIFICATE=your-certificate-base64

# OIDC Configuration (optional)
# OIDC_ISSUER=https://your-idp.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret

# ===========================================
# ENCRYPTION
# ===========================================
# Master encryption key for server-side encryption
# Must be 32 bytes, base64 encoded
# ENCRYPTION_MASTER_KEY=your-32-byte-master-key

# ===========================================
# COMPLIANCE & AUDIT
# ===========================================
# Audit log retention period in days
# AUDIT_RETENTION_DAYS=2555

# Data retention periods (in days)
# DATA_RETENTION_MESSAGES=365
# DATA_RETENTION_CONVERSATIONS=730
# DATA_RETENTION_MEMORIES=1095

# ===========================================
# SECURITY (Required for Production)
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your-64-char-random-secret

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your-64-char-encryption-key

# Comma-separated admin emails for SSO provider management
ADMIN_EMAILS=admin@example.com

# ===========================================
# OPTIONAL: AI PROVIDER KEYS
# ===========================================
# These are stored per-user, encrypted
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# GOOGLE_AI_API_KEY=your-google-key

# GitHub Models (FREE - uses GitHub PAT)
# 1. Go to https://github.com/settings/tokens
# 2. Create new token (classic) with "models" scope
# 3. Use the token as your API key in Settings
# GITHUB_PAT=ghp_your_personal_access_token

# ===========================================
# EMAIL (Mailjet - 6000 free emails/month)
# ===========================================
# Get your API keys from https://www.mailjet.com/
# MAILJET_API_KEY=your_mailjet_api_key
# MAILJET_API_SECRET=your_mailjet_api_secret
# EMAIL_FROM=TaskLyne <noreply@yourdomain.com>
